# ─────────────────────────────────────────────────────────
#  Ionix Partner API — Environment Variables Template
#  Copiaza in .env si completeaza valorile reale
# ─────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://ionix_user:ionix_dev_pass_2024@127.0.0.1:5432/ionix_partner

# ── JWT ───────────────────────────────────────────────────
# Genereaza cu: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=SCHIMBA_ACESTA_CU_UN_SECRET_RANDOM_64_CHARS
JWT_REFRESH_SECRET=SCHIMBA_ACESTA_CU_ALT_SECRET_RANDOM_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── File uploads ──────────────────────────────────────────
UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760   # 10 MB (default)

# ── Telegram notifications ────────────────────────────────
# Obtine token de la @BotFather pe Telegram
TELEGRAM_BOT_TOKEN=
# ID-ul chat-ului / grupului unde se trimit notificarile
TELEGRAM_CHAT_ID=

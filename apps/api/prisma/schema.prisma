// ─────────────────────────────────────────────────────────────────────────────
//  Ionix Partner — Prisma Schema
//  Database: PostgreSQL 16
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN         // system superadmin — acces complet
  VIEWER        // system observer — doar vizualizare, fără acțiuni
  PARTNER_ADMIN // primul utilizator al unui Partener — admin la nivel de firmă
  PARTNER       // păstrat pentru compatibilitate (tratat ca PARTNER_ADMIN)
  MANAGER       // utilizator partener — poate depune + vedea toate + anulează doar ale sale
}

enum ApplicationStatus {
  PENDING      // freshly submitted
  PROCESSING   // operator picked it up
  APPROVED     // credit approved
  REJECTED     // credit rejected
  CANCELLED    // partner cancelled
}

enum CreditType {
  ZERO    // 0% interest — marketing product
  CLASSIC // standard amortization
}

enum DocumentType {
  ID_FRONT
  ID_BACK
  SELFIE
  OTHER
}

// ─────────────────────────────────────────────
//  User
// ─────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String?   @unique   // required for ADMIN/VIEWER; optional for parteneri
  username    String?   @unique   // login pentru conturi de Partener
  password    String              // bcrypt hash — NEVER store plaintext
  firstName   String
  lastName    String
  role        Role      @default(MANAGER)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  partnerId   String?
  partner     Partner?  @relation(fields: [partnerId], references: [id])
  auditLogs   AuditLog[]
  refreshTokens RefreshToken[]
  createdApplications        Application[] @relation("CreatedApplications")

  @@index([email])
  @@index([username])
  @@index([partnerId])
  @@map("users")
}

// ─────────────────────────────────────────────
//  Refresh Token (rotation strategy)
// ─────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  ipAddress String?

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
//  Partner (extends User for PARTNER role)
// ─────────────────────────────────────────────

model Partner {
  id             String   @id @default(cuid())

  companyName    String
  commissionRate Float    @default(0.0)
  logoPath       String?  // relative path under /uploads/logos/

  calculatorConfig Json?

  // Per-partner Telegram (overrides global settings)
  telegramBotToken  String?
  telegramChatId    String?
  telegramEnabled   Boolean @default(true)

  users          User[]
  applications   Application[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("partners")
}

// ─────────────────────────────────────────────
//  Application (credit request)
// ─────────────────────────────────────────────

model Application {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id])

  createdByUserId      String?
  createdByUser        User?   @relation("CreatedApplications", fields: [createdByUserId], references: [id], onDelete: SetNull)

  statusChangedByName  String?   // name of whoever last changed the status (web user or Telegram operator)

  // ── Client personal data ────────────────────
  clientFirstName  String
  clientLastName   String
  clientIdnp       String             // MD national ID number
  clientPhone      String
  clientEmail      String?
  clientAddress    String?

  // ── Credit parameters ───────────────────────
  creditType    CreditType
  amount        Decimal    @db.Decimal(12, 2)
  months        Int
  monthlyRate   Decimal?   @db.Decimal(6, 4)  // decimal rate, e.g. 0.0299

  // ── Calculated snapshot (persisted at submit time) ──────
  monthlyPayment Decimal   @db.Decimal(12, 2)
  totalAmount    Decimal   @db.Decimal(12, 2)  // VTP
  dae            Decimal   @db.Decimal(6, 2)   // Annual Effective Rate %
  commissionAmount Decimal @db.Decimal(12, 2) @default(0)

  // ── Lifecycle ────────────────────────────────
  status               ApplicationStatus @default(PENDING)
  telegramMessageId    String?
  processorNotes       String?
  rejectionReason      String?

  documents    Document[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("applications")
}

// ─────────────────────────────────────────────
//  Document (uploaded files)
// ─────────────────────────────────────────────

model Document {
  id            String       @id @default(cuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type          DocumentType @default(OTHER)
  filename      String       // stored filename (UUID-based)
  originalName  String       // original filename from client
  mimeType      String
  sizeBytes     Int
  path          String       // relative path under /uploads

  createdAt     DateTime @default(now())

  @@index([applicationId])
  @@map("documents")
}

// ─────────────────────────────────────────────
//  AuditLog (immutable event trail)
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      String   // e.g. LOGIN, CALCULATE, SUBMIT_APPLICATION, DOWNLOAD_PDF
  resource    String?  // e.g. application, calculator, user
  resourceId  String?
  ipAddress   String
  userAgent   String?
  metadata    Json?    // any extra structured data

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
//  Setting (key-value store for global config)
// ─────────────────────────────────────────────

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique  // e.g. CLASSIC_MONTHLY_RATE, MAX_AMOUNT_ZERO
  value       String            // always stored as string, parsed by service
  type        String   @default("string")  // string | number | boolean | json
  label       String?           // human-readable label for admin UI
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("settings")
}
